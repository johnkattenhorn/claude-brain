{
  "schema_version": "1.0.0",
  "merge_confidence_threshold": 0.8,
  "auto_sync": true,
  "max_memory_lines": 200,
  "max_merge_log_entries": 200,
  "max_budget_usd": 0.50,
  "merge_model": "sonnet",
  "push_retry_attempts": 3,
  "push_retry_delay_seconds": 2,
  "sync_timeout_seconds": 30,
  "stale_threshold_days": 14,
  "encryption": {
    "enabled": false
  },
  "evolve_interval_days": 7,
  "profiles": {
    "full": {
      "description": "Sync everything (default)",
      "categories": "all"
    },
    "memory-only": {
      "description": "Only sync memory and CLAUDE.md — no skills, agents, or settings",
      "categories": "memory,claude_md"
    },
    "knowledge": {
      "description": "Sync knowledge artifacts only — no settings or environmental config",
      "categories": "memory,claude_md,rules,skills,agents"
    }
  }
}
